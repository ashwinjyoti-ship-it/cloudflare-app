{
  "name": "cloudflare-fullstack-app",
  "private": true,
  "version": "1.0.0",
  "description": "Full-stack app with Cloudflare Workers, Pages, D1, and GitHub Actions",
  "scripts": {
    "dev:api": "cd apps/api && npm run dev",
    "dev:web": "cd apps/web && npm run dev",
    "build:web": "cd apps/web && npm run build",
    "deploy:api": "cd apps/api && npm run deploy",
    "db:generate": "cd apps/api && npm run db:generate",
    "db:migrate": "cd apps/api && npm run db:migrate"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {}
}
